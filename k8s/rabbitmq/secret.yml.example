# Copie para "rabbitmq-secret.yml", preencha em Base64 e NÃO commite.
# Esses valores devem ser os mesmos usados para montar a RABBITMQ_URL
# nos secrets do estoque e do pedido:
#   amqp://<RABBITMQ_USER>:<RABBITMQ_PASSWORD>@rabbitmq:5672/
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-secret
  labels:
    app: rabbitmq
type: Opaque
data:
  RABBITMQ_DEFAULT_USER: <BASE64_USER>
  RABBITMQ_DEFAULT_PASS: <BASE64_PASSWORD>
