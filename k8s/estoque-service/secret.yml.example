# Copie este arquivo para "secret.yml", preencha os valores reais e NÃO o
# commite no repositório (mantenha-o no .gitignore, assim como em auth-service).
#
# As strings em "data" precisam estar em Base64. Exemplo:
#   echo -n 'postgresql://postgres:postgres@estoque-db:5432/estoque' | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: estoque-secret
  labels:
    app: estoque
type: Opaque
data:
  DATABASE_URL: <BASE64_DATABASE_URL>
  RABBITMQ_URL: <BASE64_RABBITMQ_URL>
  JWT_SECRET: <BASE64_JWT_SECRET>
